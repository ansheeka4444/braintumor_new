# Step 2: Extract Datasets & Aggregate
import glob

print("Extracting datasets...")
with zipfile.ZipFile("brain-mri-images-for-brain-tumor-detection.zip", 'r') as zip_ref:
    zip_ref.extractall("brain_tumor_data_1")

with zipfile.ZipFile("brain-tumor-mri-dataset.zip", 'r') as zip_ref:
    zip_ref.extractall("brain_tumor_data_2")

yes_images = []
no_images = []

# Dataset 1: yes/no structure
yes_images.extend(glob.glob("brain_tumor_data_1/**/*yes*/*.*", recursive=True))
no_images.extend(glob.glob("brain_tumor_data_1/**/*no*/*.*", recursive=True))

# Dataset 2: glioma, meningioma, pituitary, notumor
yes_images.extend(glob.glob("brain_tumor_data_2/**/*glioma*/*.*", recursive=True))
yes_images.extend(glob.glob("brain_tumor_data_2/**/*meningioma*/*.*", recursive=True))
yes_images.extend(glob.glob("brain_tumor_data_2/**/*pituitary*/*.*", recursive=True))
no_images.extend(glob.glob("brain_tumor_data_2/**/*notumor*/*.*", recursive=True))

print(f"Total 'Yes' (Tumor) Images: {len(yes_images)}")
print(f"Total 'No' (Healthy) Images: {len(no_images)}")


# Step 3: Show Sample MRI Image
sample_img = random.choice(yes_images)
image = plt.imread(sample_img)
plt.imshow(image)
plt.title("Sample MRI Image (Tumor)")
plt.axis('off')
