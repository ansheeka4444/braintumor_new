# Step 4: Dataset Distribution Visualization
labels = ['Tumor','No Tumor']
counts = [len(yes_images), len(no_images)]

plt.bar(labels, counts)
plt.title("Dataset Distribution (Merged)")
plt.show()


# Step 5: Create Train/Validation Folders
os.makedirs("dataset/train/yes", exist_ok=True)
os.makedirs("dataset/train/no", exist_ok=True)
os.makedirs("dataset/val/yes", exist_ok=True)
os.makedirs("dataset/val/no", exist_ok=True)

train_yes, val_yes = train_test_split(yes_images, test_size=0.2, random_state=42)
train_no, val_no = train_test_split(no_images, test_size=0.2, random_state=42)

# different dataset may have same name so here we are renaming the files 
def copy_files(file_list, destination_folder):
    for i, file_path in enumerate(file_list):
        if not os.path.isfile(file_path): continue
        extension = os.path.splitext(file_path)[1]
        new_name = f"image_{i}{extension}"
        shutil.copy(file_path, os.path.join(destination_folder, new_name))

print("Copying files to train/val folders... this may take a moment.")
copy_files(train_yes, "dataset/train/yes/")
copy_files(val_yes, "dataset/val/yes/")
copy_files(train_no, "dataset/train/no/")
copy_files(val_no, "dataset/val/no/")


# Step 6: Data Preprocessing + Augmentation
train_gen = ImageDataGenerator(
    rescale=1./255,
    rotation_range=20,
    zoom_range=0.2,
    horizontal_flip=True
)

val_gen = ImageDataGenerator(rescale=1./255)

train_data = train_gen.flow_from_directory(
    "dataset/train",
    target_size=(128,128),
    batch_size=32,
    class_mode='binary'
)

val_data = val_gen.flow_from_directory(
    "dataset/val",
    target_size=(128,128),
    batch_size=32,
    class_mode='binary',
    shuffle=False
)


# Step 7: CNN Model
model = Sequential([
    Conv2D(32,(3,3),activation='relu',input_shape=(128,128,3)),
    MaxPooling2D(2,2),

    Conv2D(64,(3,3),activation='relu'),
    MaxPooling2D(2,2),

    Flatten(),

    Dense(128,activation='relu'),
    Dropout(0.5),

    Dense(1,activation='sigmoid')
])


# Step 8: Model Summary
model.summary()


# Step 9: Compile Model
model.compile(
    optimizer='adam',
    loss='binary_crossentropy',
    metrics=['accuracy']
)


# Step 10: Early Stopping
early_stop = EarlyStopping(
    monitor='val_loss',
    patience=3,
    restore_best_weights=True
)


# Step 11: Train Model
history = model.fit(
    train_data,
    epochs=20,
    validation_data=val_data,
    callbacks=[early_stop]
)


# Step 12: Accuracy Graph
plt.plot(history.history['accuracy'], label='Train Accuracy')
plt.plot(history.history['val_accuracy'], label='Validation Accuracy')
plt.title("Model Accuracy")
plt.legend()
plt.show()


# Step 13: Loss Graph
plt.plot(history.history['loss'], label='Train Loss')
plt.plot(history.history['val_loss'], label='Validation Loss')
plt.title("Model Loss")
plt.legend()
plt.show()


# Step 14: Training Results Table
results = pd.DataFrame({
    "Epoch": range(1,len(history.history['accuracy'])+1),
    "Train Accuracy": history.history['accuracy'],
    "Validation Accuracy": history.history['val_accuracy']
})

print(results)


# Step 15: Confusion Matrix
val_data.reset()

predictions = model.predict(val_data)
predicted_classes = (predictions > 0.5).astype(int)

true_classes = val_data.classes

print("\nConfusion Matrix")
print(confusion_matrix(true_classes,predicted_classes))

print("\nClassification Report")
print(classification_report(true_classes,predicted_classes,target_names=["No Tumor","Tumor"]))


# Step 16: Save Model
model.save("brain_tumor_cnn_model.keras")
print("Model saved successfully!")


