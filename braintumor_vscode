def visualize_layer_activations(model_instance, img_array):
    print("\nGenerating layer-wise transformations...")
    # Get outputs of all layers
    layer_outputs = [layer.output for layer in model_instance.layers]
    layer_names = [layer.name for layer in model_instance.layers]
    
    if not layer_outputs:
        print("No layers found for visualization.")
        return
        
    # Create an activation model
    from tensorflow.keras.models import Model
    activation_model = Model(inputs=model_instance.inputs, outputs=layer_outputs)
    activations = activation_model.predict(img_array)
    
    for layer_name, layer_activation in zip(layer_names, activations):
        # Only visualize 2D spatial layers (Conv2D, MaxPooling2D)
        if len(layer_activation.shape) != 4:
            continue
            
        n_features = layer_activation.shape[-1]
        features_to_show = min(16, n_features) # Show up to 16 feature maps
        
        cols = 4
        rows = int(np.ceil(features_to_show / cols))
        
        fig, axes = plt.subplots(rows, cols, figsize=(cols * 2.5, rows * 2.5))
        fig.suptitle(f'Layer Transformation: {layer_name}', fontsize=16)
        axes = (axes.flatten() if isinstance(axes, np.ndarray) else [axes])
        
        for i in range(features_to_show):
            x = layer_activation[0, :, :, i]
            # Post-process the feature to make it visually clear
            x -= x.mean()
            if x.std() > 0:
                x /= x.std()
            x *= 64
            x += 128
            x = np.clip(x, 0, 255).astype('uint8')
            
            axes[i].imshow(x, cmap='viridis')
            axes[i].axis('off')
            axes[i].set_title(f'Filter {i+1}', fontsize=10)
            
        for j in range(features_to_show, len(axes)):
            axes[j].axis('off')
            
        plt.tight_layout()
        plt.show()

def predict_image(img_path, show_layers=False):

    img = load_img(img_path, target_size=(128,128))
    img_array = img_to_array(img) / 255
    img_array = np.expand_dims(img_array, axis=0)

    prediction = model.predict(img_array)

    probability = prediction[0][0]

    if probability > 0.5:
        confidence = probability * 100
        result = f"Tumor Detected"
    else:
        confidence = (1 - probability) * 100
        result = f"No Tumor Detected"

    plt.imshow(img)
    plt.title(f"{result}\nConfidence: {confidence:.2f}%")
    plt.axis('off')
    plt.show()

    print("Prediction:", result)
    print("Confidence:", f"{confidence:.2f}%")

    if show_layers:
        visualize_layer_activations(model, img_array)

